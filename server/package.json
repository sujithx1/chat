{
  "name": "server",
  "scripts": {
    "dev": "bun run --watch src/server.ts ",
    "build": "bun build src/server.ts --outdir dist --target node",
    "start": " bun run --env-file=.env dist/server.js",
    "g": "bun drizzle-kit generate",
    "m": "bun drizzle-kit migrate",
    "lint": "eslint --ext .ts,.tsx . --fix",
    "fmt": "prettier --write ."
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.13.11",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.30.1",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1"
  }
}
